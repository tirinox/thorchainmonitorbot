{% set _width, _height = set_viewport_size(1280, 720) %}
{% extends "base.jinja2" %}

{% block content %}

    {% set is_rapid_swap = rapid_swap_stats and rapid_swap_stats.blocks_saved > 0 %}
    {% set rapid_saved_seconds = (rapid_swap_stats.saved_time | round | int) if is_rapid_swap else 0 %}
    {% if is_rapid_swap %}
        {% if rapid_saved_seconds >= 3600 %}
            {% set rapid_saved_time_text = '%02d:%02d:%02d saved' % (rapid_saved_seconds // 3600, (rapid_saved_seconds % 3600) // 60, rapid_saved_seconds % 60) %}
        {% else %}
            {% set rapid_saved_time_text = '%02d:%02d saved' % (rapid_saved_seconds // 60, rapid_saved_seconds % 60) %}
        {% endif %}
    {% else %}
        {% set rapid_saved_time_text = '' %}
    {% endif %}

    {% with title="SWAP FINISHED ✅", header_badge="⚡ RAPID SWAP" if is_rapid_swap else "", header_badge_extra=rapid_saved_time_text if is_rapid_swap else "" %}
        {% include "components/header.jinja2" %}
    {% endwith %}

    <style>
        .bg {
            background: url("renderer/static/img/bg2.svg") no-repeat center -79px;
        }

        .liquidity-fee-block {
            color: white;
            font-size: 32px;
            font-weight: bolder;
            position: absolute;
            top: -15%;
        }

        .refund-text {
            color: #e85555;
            font-weight: bolder;
            text-wrap: nowrap;
            padding-bottom: 0;
            display: block;
            text-align: center;

            font-size: 30px;
            font-style: italic;
        }

        .arrow-refund {
            width: 200px;
            filter: brightness(100%) hue-rotate(220deg) saturate(200%) drop-shadow(3px 3px 4px rgba(255, 0, 0, 0.51)) drop-shadow(-3px -3px 4px rgba(255, 76, 76, 0.51));
            margin: 5px;
            padding: 0;
            transform: scale(-1, 1);
        }

        .arrow-lr-squished {
            margin: 5px;
            padding: 0;
            transform: scale(1, 1);
        }

        .arrow-vert-stack {
            display: flex;
            width: 200px;
            flex-direction: column;
            padding: 0;
        }

        .streaming-count {
            font-weight: bolder;
            font-size: 30px;
            margin-left: -8px;
        }

        .header-box {
            top: 18px;
        }


        .rapid-swap-meta {
            width: 300px;
            bottom: 138px;
            transform: translateX(-42px);
        }

        .rapid-saved-blocks {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            padding: 11px 16px 12px;
            margin-top: 4px;
            box-shadow: 0 0 18px rgba(0, 0, 0, 0.28);
        }

        .rapid-saved-blocks-main {
            font-size: 24px;
            color: #f5c518;
            font-weight: 800;
            line-height: 1.05;
            text-shadow: 0 0 12px rgba(245, 197, 24, 0.2);
        }

        .rapid-saved-blocks-sub {
            font-size: 21px;
            color: #fff2b1;
            font-weight: 700;
            line-height: 1;
        }

        .time-stack {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
        }

        .time-block-flex.rapid-time-block {
            align-items: center;
            gap: 10px;
        }

        .rapid-time-block .clock {
            padding: 6px 8px 6px 3px;
        }

        .rapid-time-block .wait-time {
            margin-bottom: 0;
            font-size: 46px;
            font-weight: 500;
            line-height: 1;
        }

    </style>

    <div class="route-box">
        <div id="source_logo" class="logo-holder">
            <div class="logo-part">

                {% with asset_name=source_asset, asset_logo=source_asset_logo, chain_logo=source_chain_logo %}
                    {% include "components/asset-logo.jinja2" %}
                {% endwith %}

                <div class="asset-part">
                    <div class="user-name">
                        {{ "🤖" if "Arb-Bot" in source_user_name else "👤" }}
                        {{ source_user_name }}
                    </div>
                    <div class="input-amount">
                        {{ short_money(source_amount) }} {{ source_asset_name }}
                    </div>
                    <div class="usd-volume">
                        ({{ short_dollar(source_volume_usd) }})
                    </div>
                </div>
            </div>

        </div>

        <div class="line-box">

            <div class="arrow-vert-stack">
                {% if refund %}

                    {% with f=70 * (refund_rate / 100) %}
                        <img src="renderer/static/img/arrow2.png" alt="Arrow refund" class="arrow-refund shadow"
                             style="height: {{ f }}px"
                        >
                        <img src="renderer/static/img/arrow2.png" alt="Arrow right"
                             class="arrow-lr arrow-lr-squished shadow"
                             style="height: {{ 70 - f }}px"
                        >
                    {% endwith %}
                {% else %}
                    <img src="renderer/static/img/arrow2.png" alt="Arrow right" class="arrow-lr shadow">
                {% endif %}
            </div>
            <div class="above-arrow tx-id-block">
                {% if refund %}
                    <span class="refund-text">{{ pretty_money(refund_rate) }}% refund</span>
                {% endif %}
            </div>
        </div>

        <div class="logo-holder">
            <img class="circle-tc-logo tc-glow" src="renderer/static/img/tc_logo_circle.png?rv=1" alt="THORChain logo">

            <div class="liquidity-fee-block">
                LP fee
                <span class="highlight-blue">{{ pretty_money(round(liquidity_fee_percent, 3)) }}%</span>
            </div>

            <div class="arrow-down-holder">
                <img src="renderer/static/img/arrow2-down.png" alt="Arrow down"
                     class="shadow arrow-down {{ "arrow-aff" if affiliate_names else "arrow-no-aff" }}">

                {% include "components/aff-logo-fan.jinja2" %}
            </div>

        </div>

        <div class="line-box">
            <img src="renderer/static/img/arrow2.png" alt="Arrow right" class="arrow-lr shadow">
            {% if (streaming_count and streaming_count > 1) or is_rapid_swap %}
                <div class="above-arrow streaming-count midgard-turqoise {{ "rapid-swap-meta" if is_rapid_swap else "" }}">
                    {% if is_rapid_swap %}
                        <div class="rapid-saved-blocks">
                            <div class="rapid-saved-blocks-main">
                                ⚡ {{ rapid_swap_stats.streaming_swap_quantity or rapid_swap_stats.total_swaps }} subswaps
                            </div>
                            <div class="rapid-saved-blocks-sub">
                                in {{ rapid_swap_stats.distinct_blocks }} blocks
                            </div>
                        </div>
                    {% elif streaming_count and streaming_count > 1 %}
                        {{ streaming_count }} subswaps
                    {% endif %}
                </div>
            {% endif %}
        </div>

        <div id="dest_logo" class="logo-holder">
            <div class="logo-part">
                {% with asset_name=destination_asset, asset_logo=destination_logo, chain_logo=destination_chain_logo,
                        right=True %}
                    {% include "components/asset-logo.jinja2" %}
                {% endwith %}

                <div class="asset-part">
                    <div class="user-name">
                        {{ "🤖" if "Arb-Bot" in destination_user_name else "👤" }}
                        {{ destination_user_name }}
                    </div>

                    <div class="output-amount">
                        {% if destination_amount %}
                            ≈{{ short_money(destination_amount) }} {{ destination_asset_name }}
                        {% else %}
                            ≈ N/A {{ destination_asset_name }}
                        {% endif %}
                    </div>
                    <div class="usd-volume">
                        ({{ short_dollar(destination_volume_usd) }})
                    </div>

                    <div class="time-block-flex {{ "rapid-time-block" if is_rapid_swap else "" }}" id="time-block">
                        <img src="renderer/static/img/time-is-money.png" alt="Time is money..." class="clock">
                        <div class="time-stack">
                            <div class="wait-time" id="wait-time"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script>
        const waitTimeSec = {{ total_time_sec }};

        const formatTime = (time) => {
            const pad = (num) => String(num).padStart(2, '0');
            const hours = Math.floor(time / 3600);
            const minutes = Math.floor((time % 3600) / 60);
            const seconds = time % 60;
            return hours > 0 ? `${pad(hours)}:${pad(minutes)}:${pad(seconds)}` : `${pad(minutes)}:${pad(seconds)}`;
        };

        if (waitTimeSec !== 0) {
            document.querySelector('#wait-time').textContent = formatTime(waitTimeSec);
        } else {
            // hide #time-block
            document.querySelector('#time-block').style.display = 'none';
        }
    </script>

{% endblock %}
