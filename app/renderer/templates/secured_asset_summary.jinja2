{% set _width, _height = set_viewport_size(1440, 1080) %}
{% extends "base.jinja2" %}

{% block content %}
{% set top_n = 6 %}
    <style>
        /* ── period pill ─────────────────────────────────────── */
        .period-pill {
            position: absolute;
            top: 39px;
            right: 34px;
            padding: 13px 20px;
            border-radius: 14px;
            background: rgba(18, 34, 37, .85);
            border: 1px solid rgba(55, 255, 173, .16);
            text-align: right;
            min-width: 280px;
        }

        .period-main {
            font-size: 26px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 3px;
            text-transform: uppercase;
            letter-spacing: .1em;
        }

        .period-sub {
            font-size: 17px;
            color: #97b8b0;
            text-transform: uppercase;
            letter-spacing: .08em;
        }

        /* ── main layout ─────────────────────────────────────── */
        .layout {
            position: absolute;
            top: 140px;
            left: 30px;
            right: 30px;
            bottom: 52px;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        /* ── stat cards ──────────────────────────────────────── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 16px;
        }

        .card {
            padding: 18px 22px 16px;
            border-radius: 18px;
            background: linear-gradient(180deg, rgba(18, 29, 35, .94), rgba(10, 16, 21, .95));
            border: 1px solid rgba(255, 255, 255, .05);
        }

        .card-title {
            color: #91a3a9;
            font-size: 20px;
            text-transform: uppercase;
            letter-spacing: .18em;
            font-weight: 400;
            margin-bottom: 8px;
        }

        .card-value {
            color: #fff;
            font-size: 50px;
            font-weight: 800;
            line-height: 1.05;
            text-shadow: rgba(35, 220, 200, .14) 0 0 16px;
        }

        .card-delta {
            font-size: 18px;
            color: #637870;
            margin-top: 4px;
        }

        /* ── panel (table wrapper) ───────────────────────────── */
        .panel {
            border-radius: 20px;
            padding: 18px 22px 14px;
            background: linear-gradient(180deg, rgba(15, 24, 30, .97), rgba(9, 14, 19, .98));
            border: 1px solid rgba(255, 255, 255, .05);
            flex: 1;
            min-height: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .panel-title {
            color: #fff;
            font-size: 28px;
            font-weight: 800;
            letter-spacing: .08em;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        /* ── table header ────────────────────────────────────── */
        .table-head {
            display: flex;
            flex-direction: row;
            align-items: center;
            color: #91a3a9;
            font-size: 21px;
            font-weight: 400;
            text-transform: uppercase;
            letter-spacing: .14em;
            padding: 4px 10px 12px;
            border-bottom: 1px solid rgba(255, 255, 255, .10);
            margin-bottom: 4px;
        }

        /* ── asset rows ──────────────────────────────────────── */
        .flex-all-center {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .logo-box {
            min-width: 52px;
            flex-shrink: 0;
        }

        .asset-logo {
            width: 38px;
            height: 38px;
            filter: drop-shadow(0 0 5px rgba(0, 170, 255, .55));
        }

        .asset-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            padding: 10px 10px;
            border-bottom: 1px solid rgba(255, 255, 255, .05);
        }

        .asset-row:last-child {
            border-bottom: none;
        }

        .col {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            justify-content: center;
            flex: 1;
        }

        .col-name {
            flex: 0 0 200px;
            align-items: flex-start;
            justify-content: center;
            font-size: 32px;
            font-weight: 500;
            color: #fff;
            letter-spacing: .02em;
            padding-left: 10px;
        }

        .others-row { border-top: 1px solid rgba(255, 255, 255, .08); margin-top: 4px; }
        .others-name { color: #7a9099; font-style: italic; }
        .others-badge {
            width: 38px; height: 38px;
            border-radius: 50%;
            background: rgba(255, 255, 255, .06);
            border: 1px solid rgba(255, 255, 255, .12);
            color: #7a9099;
            font-size: 15px; font-weight: 700;
            display: flex; align-items: center; justify-content: center;
            letter-spacing: -.02em;
        }

        .col-holders {
            flex: 0 0 160px;
        }

        .col-val {
            font-size: 36px;
            font-weight: 800;
            color: #fff;
            text-shadow: rgba(35, 220, 200, .10) 0 0 10px;
        }

        .col-sub {
            font-size: 18px;
            color: #637870;
            margin-top: 2px;
        }

        /* header column stubs */
        .th {
            flex: 1;
            text-align: right;
            justify-content: flex-end;
            display: flex;
            align-items: center;
        }

        .th-name {
            flex: 0 0 252px;
            text-align: left;
            justify-content: flex-start;
        }

        .th-holders {
            flex: 0 0 160px;
            text-align: right;
            justify-content: flex-end;
        }
    </style>

    {% with title="SECURED ASSETS" %}
        {% include "components/header.jinja2" %}
    {% endwith %}

    <div class="period-pill shadow-box">
        <div class="period-main">{{ current.total_assets }} Assets</div>
        <div class="period-sub">Secured on THORChain</div>
    </div>

    <div class="layout">

        {# ── stat cards ──────────────────────────────────────── #}
        <div class="stats-grid">

            <div class="card shadow-box">
                <div class="card-title">🔒 Total assets</div>
                <div class="card-value">{{ current.total_assets }}</div>
                <div class="card-delta">
                    {% with prev=previous.total_assets, curr=current.total_assets, abs_value=True %}
                        {% include "components/delta.jinja2" %}
                    {% endwith %}
                </div>
            </div>

            <div class="card shadow-box">
                <div class="card-title">💰 Secured depth</div>
                <div class="card-value">{{ short_dollar(current.total_value_usd) }}</div>
                <div class="card-delta">
                    {% with prev=previous.total_value_usd, curr=current.total_value_usd %}
                        {% include "components/delta.jinja2" %}
                    {% endwith %}
                </div>
            </div>

            <div class="card shadow-box">
                <div class="card-title">📊 Secured / pool</div>
                <div class="card-value">{{ "%.1f"|format(current.total_secured_to_pool_percentage) }}%</div>
                <div class="card-delta">
                    {% with prev=previous.total_secured_to_pool_percentage,
                            curr=current.total_secured_to_pool_percentage,
                            abs_value=True, epilogue=' p.p.' %}
                        {% include "components/delta.jinja2" %}
                    {% endwith %}
                </div>
            </div>

            <div class="card shadow-box">
                <div class="card-title">📈 Volume 24h</div>
                <div class="card-value">{{ short_dollar(current.total_volume_24h_usd) }}</div>
                <div class="card-delta">
                    {% with prev=previous.total_volume_24h_usd, curr=current.total_volume_24h_usd %}
                        {% include "components/delta.jinja2" %}
                    {% endwith %}
                </div>
            </div>

        </div>

        {# ── asset table panel ───────────────────────────────── #}
        <div class="panel shadow-box">

            <div class="table-head">
                <div class="logo-box"></div>
                <div class="th-name">Name</div>
                <div class="th">Total supply</div>
                <div class="th">Value USD</div>
                <div class="th th-holders">Holders</div>
                <div class="th">Volume 24h</div>
            </div>

            {% for asset_name in current.asset_names_sorted[:top_n] %}
                {% set curr_a = current.assets[asset_name] %}
                {% set prev_a = previous.assets.get(asset_name, {}) %}

                <div class="asset-row">

                    <div class="logo-box flex-all-center">
                        <img class="asset-logo"
                             src="renderer/logo/{{ curr_a['l1_name'] }}.png"
                             alt="{{ curr_a['l1_name'] }}">
                    </div>

                    <div class="col col-name">{{ curr_a["display_name"] }}</div>

                    <div class="col">
                        <div class="col-val">{{ short_money(curr_a["supply"]) }}</div>
                        <div class="col-sub">
                            {% with curr=curr_a["supply"], prev=prev_a.get("supply", curr_a["supply"]) %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>

                    <div class="col">
                        <div class="col-val">{{ short_dollar(curr_a["value_usd"]) }}</div>
                        <div class="col-sub">
                            {% with curr=curr_a["value_usd"], prev=prev_a.get("value_usd", curr_a["value_usd"]) %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>

                    <div class="col col-holders">
                        <div class="col-val">{{ short_money(curr_a["holders"], integer=True) }}</div>
                        <div class="col-sub">
                            {% with curr=curr_a["holders"], prev=prev_a.get("holders", curr_a["holders"]) %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>

                    <div class="col">
                        <div class="col-val">{{ short_dollar(curr_a["volume_24h_usd"]) }}</div>
                        <div class="col-sub">
                            {% with curr=curr_a["volume_24h_usd"], prev=prev_a.get("volume_24h_usd", curr_a["volume_24h_usd"]) %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>

                </div>
            {% endfor %}

            {# ── "all others" aggregated row ─────────────────── #}
            {% set ns = namespace(supply=0, value_usd=0, holders=0, volume_24h_usd=0, count=0) %}
            {% set pns = namespace(supply=0, value_usd=0, holders=0, volume_24h_usd=0) %}
            {% for asset_name in current.asset_names_sorted[top_n:] %}
                {% set ca = current.assets[asset_name] %}
                {% set pa = previous.assets.get(asset_name, {}) %}
                {% set ns.supply        = ns.supply        + ca["supply"] %}
                {% set ns.value_usd     = ns.value_usd     + ca["value_usd"] %}
                {% set ns.holders       = ns.holders       + ca["holders"] %}
                {% set ns.volume_24h_usd= ns.volume_24h_usd+ ca["volume_24h_usd"] %}
                {% set ns.count         = ns.count + 1 %}
                {% set pns.supply        = pns.supply        + pa.get("supply",         ca["supply"]) %}
                {% set pns.value_usd     = pns.value_usd     + pa.get("value_usd",      ca["value_usd"]) %}
                {% set pns.holders       = pns.holders       + pa.get("holders",        ca["holders"]) %}
                {% set pns.volume_24h_usd= pns.volume_24h_usd+ pa.get("volume_24h_usd", ca["volume_24h_usd"]) %}
            {% endfor %}

            {% if ns.count > 0 %}
            <div class="asset-row others-row">

                <div class="logo-box flex-all-center">
                    <div class="others-badge">+{{ ns.count }}</div>
                </div>

                <div class="col col-name others-name">{{ ns.count }} others</div>

                <div class="col">
                    <div class="col-val" style="color: #4a6068;">—</div>
                </div>

                <div class="col">
                    <div class="col-val">{{ short_dollar(ns.value_usd) }}</div>
                    <div class="col-sub">
                        {% with curr=ns.value_usd, prev=pns.value_usd %}
                            {% include "components/delta.jinja2" %}
                        {% endwith %}
                    </div>
                </div>

                <div class="col col-holders">
                    <div class="col-val">{{ short_money(ns.holders, integer=True) }}</div>
                    <div class="col-sub">
                        {% with curr=ns.holders, prev=pns.holders %}
                            {% include "components/delta.jinja2" %}
                        {% endwith %}
                    </div>
                </div>

                <div class="col">
                    <div class="col-val">{{ short_dollar(ns.volume_24h_usd) }}</div>
                    <div class="col-sub">
                        {% with curr=ns.volume_24h_usd, prev=pns.volume_24h_usd %}
                            {% include "components/delta.jinja2" %}
                        {% endwith %}
                    </div>
                </div>

            </div>
            {% endif %}

        </div>

    </div>

{% endblock %}
