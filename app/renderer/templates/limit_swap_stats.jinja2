{% set _width, _height = set_viewport_size(1440, 1020) %}
{% extends "base.jinja2" %}

{% block content %}
{% set daily     = daily     or [] %}
{% set top_pairs = top_pairs or [] %}
{% set days      = period_days | int %}

{# ── helpers ─────────────────────────────────────────────── #}
{% macro short_asset(full) -%}
  {%- if '.' in full -%}{{- full.split('.', 1)[1].split('-')[0] -}}
  {%- else -%}{{- full.split('-')[0] -}}{%- endif -%}
{%- endmacro %}

{% macro pair_label(pair_str) -%}
  {%- set sides = pair_str.split('->') -%}
  {{- short_asset(sides[0]) }} ⇄ {{ short_asset(sides[1]) -}}
{%- endmacro %}

{% macro delta_class(pct) -%}
  {%- set p = pct | float -%}
  {%- if p > 0 -%}delta-pos{%- elif p < 0 -%}delta-neg{%- else -%}delta-zero{%- endif -%}
{%- endmacro %}

{% macro delta_text(pct) -%}
  {%- set p = pct | float -%}
  {%- if p > 0 -%}+{%- endif -%}{{ '%.1f' | format(p) }}%
{%- endmacro %}

<style>
  /* ── period pill ─────────────────────────────────────── */
  .period-pill {
    position: absolute;
    top: 39px; right: 34px;
    padding: 13px 20px;
    border-radius: 14px;
    background: rgba(18,34,37,.85);
    border: 1px solid rgba(55,255,173,.16);
    text-align: right;
    min-width: 280px;
  }
  .period-main {
    font-size: 26px; font-weight: 700; color: #fff; margin-bottom: 3px;
    text-transform: uppercase; letter-spacing: .1em;
  }
  .period-sub {
    font-size: 17px; color: #97b8b0;
    text-transform: uppercase; letter-spacing: .1em;
  }

  /* ── main layout ─────────────────────────────────────── */
  .layout {
    position: absolute;
    top: 140px; left: 30px; right: 30px; bottom: 52px;
    display: flex; flex-direction: column; gap: 18px;
  }

  /* ── stat cards ──────────────────────────────────────── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }
  .card {
    padding: 20px 26px 20px;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(18,29,35,.94), rgba(10,16,21,.95));
    border: 1px solid rgba(255,255,255,.05);
  }
  .card-title {
    color: #91a3a9; font-size: 22px; text-transform: uppercase;
    letter-spacing: .18em; font-weight: 400; margin-bottom: 10px;
  }
  .card-value-row { display: flex; align-items: flex-end; gap: 16px; }
  .card-value {
    color: #fff; font-size: 64px; font-weight: 800; line-height: 1;
    text-shadow: rgba(35,220,200,.14) 0 0 16px;
  }
  .delta      { font-size: 28px; font-weight: 800; letter-spacing: .03em; padding-bottom: 5px; }
  .delta-pos  { color: #33FF99; text-shadow: rgba(51,255,153,.22) 0 0 14px; }
  .delta-neg  { color: #ff7f8a; text-shadow: rgba(255,127,138,.22) 0 0 14px; }
  .delta-zero { color: #9ca7ad; }

  /* ── content row ─────────────────────────────────────── */
  .content-row {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(420px, 1fr);
    gap: 18px; flex: 1; min-height: 0;
  }
  .panel {
    border-radius: 20px; padding: 20px 22px 16px;
    background: linear-gradient(180deg, rgba(15,24,30,.97), rgba(9,14,19,.98));
    border: 1px solid rgba(255,255,255,.05);
    min-height: 0;
  }
  .panel-title {
    color: #fff; font-size: 30px; font-weight: 800;
    letter-spacing: .08em; text-transform: uppercase; margin-bottom: 6px;
  }

  /* ── main chart ──────────────────────────────────────── */
  .chart-shell { display: flex; flex-direction: column; height: 100%; }
  .legend-row  { display: flex; gap: 22px; align-items: center; margin-bottom: 10px; }
  .legend-item { display: flex; align-items: center; gap: 8px;
                 color: #b4c4c9; font-size: 18px; }
  .legend-dot         { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0; }
  .legend-dot-orders  { background: #33FF99; }
  .legend-line        { width: 22px; height: 4px; border-radius: 2px; flex-shrink: 0; }
  .legend-line-volume { background: rgba(255,195,60,.8); }
  .chart-wrap  { flex: 1; position: relative; min-height: 0; }

  /* ── traders mini chart ──────────────────────────────── */
  .traders-section { margin-top: 12px; }
  .traders-section-label {
    font-size: 15px; color: #6ae9e0; text-transform: uppercase;
    letter-spacing: .12em; margin-bottom: 5px;
  }
  .traders-mini-wrap { height: 140px; position: relative; }

  /* ── chart footer stats ──────────────────────────────── */
  .chart-footer {
    display: grid; grid-template-columns: repeat(3, minmax(0,1fr));
    gap: 10px; margin-top: 12px;
  }
  .mini-stat  { border-radius: 13px; padding: 10px 14px; background: rgba(255,255,255,.03); }
  .mini-label { font-size: 17px; color: #9eb3ba; text-transform: uppercase;
                letter-spacing: .09em; margin-bottom: 5px; }
  .mini-value { font-size: 28px; color: #fff; font-weight: 800; }

  /* ── top pairs ───────────────────────────────────────── */
  .pairs-shell { display: flex; flex-direction: column; height: 100%; }
  .pairs-list  { display: flex; flex-direction: column; gap: 7px; flex: 1;
                 margin-top: 10px; min-height: 0; overflow: hidden; }
  .pair-row {
    display: grid;
    grid-template-columns: 44px 1fr 86px 110px;
    gap: 10px; align-items: center;
    padding: 8px 12px 8px 4px;
    border-radius: 13px;
    background: rgba(255,255,255,.03);
  }
  .pair-rank {
    width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(180deg, #33FF99, #23DCC8);
    color: #041a12; font-size: 17px; font-weight: 800;
  }
  .pair-name {
    color: #fff; font-size: 26px; font-weight: 800; letter-spacing: .03em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .pair-count { text-align: right; color: #d6f0e8; font-size: 28px; font-weight: 800; }
  .pair-usd   { text-align: right; color: #6e8a91; font-size: 22px; font-weight: 600; }
  .pair-row-others { background: rgba(255,255,255,.06); }

  /* ── empty state ─────────────────────────────────────── */
  .empty-state {
    color: #637870; font-size: 22px; margin-top: 24px;
    text-align: center; text-transform: uppercase; letter-spacing: .06em;
  }

  /* ── open orders strip ───────────────────────────────── */
  .open-strip {
    display: grid;
    grid-template-columns: auto repeat(4, minmax(0, 1fr));
    align-items: center;
    padding: 14px 22px;
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(18,29,35,.94), rgba(10,16,21,.95));
    border: 1px solid rgba(255,180,40,.18);
  }
  .open-badge {
    display: flex; align-items: center; gap: 10px;
    padding-right: 28px;
    border-right: 1px solid rgba(255,255,255,.07);
    color: rgba(255,185,45,.85); font-size: 17px; font-weight: 800;
    text-transform: uppercase; letter-spacing: .16em; white-space: nowrap;
  }
  .open-badge-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: rgba(255,185,45,.9);
    box-shadow: rgba(255,185,45,.5) 0 0 8px;
  }
  .open-cell {
    padding: 0 24px;
    border-right: 1px solid rgba(255,255,255,.06);
  }
  .open-cell:last-child { border-right: none; }
  .open-cell-label {
    font-size: 16px; color: #9eb3ba; text-transform: uppercase;
    letter-spacing: .09em; margin-bottom: 4px;
  }
  .open-cell-value {
    font-size: 34px; color: #fff; font-weight: 800; line-height: 1;
  }

  #tradersChart {
      padding-right: 22px;
  }
</style>

{# ── header ───────────────────────────────────────────────── #}
{% with title="LIMIT ORDERS" %}
  {% include "components/header.jinja2" %}
{% endwith %}

<div class="period-pill shadow-box">
  <div class="period-main">Last {{ days }} days</div>
  <div class="period-sub">Opened limit orders overview</div>
</div>

<div class="layout">

  {# ── stat cards ────────────────────────────────────────── #}
  <div class="stats-grid">

    <div class="card shadow-box">
      <div class="card-title">📋 Orders</div>
      <div class="card-value-row">
        <div class="card-value">{{ total.opened_count | int }}</div>
        <div class="delta {{ delta_class(delta.opened_count.pct) }}">{{ delta_text(delta.opened_count.pct) }}</div>
      </div>
    </div>

    <div class="card shadow-box">
      <div class="card-title">💵 Volume</div>
      <div class="card-value-row">
        <div class="card-value">{{ short_dollar(total.opened_usd) }}</div>
        <div class="delta {{ delta_class(delta.opened_usd.pct) }}">{{ delta_text(delta.opened_usd.pct) }}</div>
      </div>
    </div>

    <div class="card shadow-box">
      <div class="card-title">👤 Traders</div>
      <div class="card-value-row">
        <div class="card-value">{{ total.unique_traders | int }}</div>
        <div class="delta {{ delta_class(delta.unique_traders.pct) }}">{{ delta_text(delta.unique_traders.pct) }}</div>
      </div>
    </div>

  </div>

  {# ── content row ───────────────────────────────────────── #}
  <div class="content-row">

    {# chart panel #}
    <div class="panel chart-shell shadow-box">
      <div class="panel-title">📈 Daily activity</div>

      <div class="legend-row">
        <div class="legend-item">
          <div class="legend-dot legend-dot-orders"></div>Orders
        </div>
        <div class="legend-item">
          <div class="legend-line legend-line-volume"></div>Volume
        </div>
      </div>

      <div class="chart-wrap">
        <canvas id="limitChart"></canvas>
      </div>

      <div class="traders-section">
        <div class="traders-section-label">Unique Traders</div>
        <div class="traders-mini-wrap">
          <canvas id="tradersChart"></canvas>
        </div>
      </div>

      <div class="chart-footer">
        <div class="mini-stat">
          <div class="mini-label">🔺 Peak day</div>
          <div class="mini-value">{{ (daily | map(attribute='opened_count') | max) if daily else 0 }}</div>
        </div>
        <div class="mini-stat">
          <div class="mini-label">∼ Avg / day</div>
          <div class="mini-value">{{ ((total.opened_count | float) / (days or 1)) | round | int }}</div>
        </div>
        <div class="mini-stat">
          <div class="mini-label">👥 Peak traders</div>
          <div class="mini-value">{{ (daily | map(attribute='unique_traders') | max) if daily else 0 }}</div>
        </div>
      </div>
    </div>

    {# top pairs panel #}
    <div class="panel pairs-shell shadow-box">
      <div class="panel-title">🏆 Top pairs</div>

      {% if top_pairs %}
        {% set other = namespace(opened_count=0, opened_usd=0.0) %}
        <div class="pairs-list">
          {% for p in top_pairs[:7] %}
            <div class="pair-row">
              <div class="pair-rank">{{ loop.index }}</div>
              <div class="pair-name">{{ pair_label(p.pair) }}</div>
              <div class="pair-count">{{ p.opened_count }}</div>
              <div class="pair-usd">{{ short_dollar(p.opened_usd) }}</div>
            </div>
          {% endfor %}

          {% for p in top_pairs[7:] %}
            {% set other.opened_count = other.opened_count + (p.opened_count | int) %}
            {% set other.opened_usd = other.opened_usd + (p.opened_usd | float) %}
          {% endfor %}

          {% if top_pairs|length > 7 %}
            <div class="pair-row pair-row-others">
              <div class="pair-rank">…</div>
              <div class="pair-name">Others</div>
              <div class="pair-count">{{ other.opened_count }}</div>
              <div class="pair-usd">{{ short_dollar(other.opened_usd) }}</div>
            </div>
          {% endif %}
        </div>
      {% else %}
        <div class="empty-state">No data</div>
      {% endif %}
    </div>

  </div>

  {# ── open orders strip ─────────────────────────────────── #}
  {% set oo = open_orders %}
  {% if oo and oo.total_count %}
  <div class="open-strip shadow-box">
    <div class="open-badge">
      <div class="open-badge-dot"></div>⏳ Open now
    </div>
    <div class="open-cell">
      <div class="open-cell-label">📦 Orders</div>
      <div class="open-cell-value">{{ oo.total_count | int }}</div>
    </div>
    <div class="open-cell">
      <div class="open-cell-label">💰 Value</div>
      <div class="open-cell-value">{{ short_dollar(oo.total_value_usd) }}</div>
    </div>
    <div class="open-cell">
      <div class="open-cell-label">⌛ Oldest</div>
      <div class="open-cell-value">{{ oo.oldest_swap_duration }}</div>
    </div>
    <div class="open-cell">
      <div class="open-cell-label">⏱ Avg age</div>
      <div class="open-cell-value">{{ oo.average_age_duration }}</div>
    </div>
  </div>
  {% endif %}

</div>

<script>
  const dailyRaw   = {{ daily | tojson }};
  const labels     = dailyRaw.map(d => { const [,mo,day] = d.date.split('-'); return `${day}.${mo}`; });
  const ordersData = dailyRaw.map(d => d.opened_count   || 0);
  const volData    = dailyRaw.map(d => d.opened_usd     || 0);
  const traderData = dailyRaw.map(d => d.unique_traders || 0);

  Chart.defaults.font.family = 'ThorFontLight, sans-serif';
  Chart.defaults.color = '#b7c8cc';

  // ── main chart (orders + volume) ──────────────────────────
  const ctx = document.getElementById('limitChart').getContext('2d');

  const gradOrders = ctx.createLinearGradient(0, 0, 0, 400);
  gradOrders.addColorStop(0, 'rgba(51,255,153,.44)');
  gradOrders.addColorStop(1, 'rgba(51,255,153,.03)');

  const gradVol = ctx.createLinearGradient(0, 0, 0, 400);
  gradVol.addColorStop(0, 'rgba(255,195,60,.20)');
  gradVol.addColorStop(1, 'rgba(255,195,60,.01)');

  new Chart(ctx, {
    data: {
      labels,
      datasets: [
        {   /* USD volume — ambient amber area, hidden axis */
          type: 'line', label: 'Volume',
          data: volData,
          borderColor: 'rgba(255,195,60,.55)', backgroundColor: gradVol,
          pointRadius: 0, borderWidth: 2, tension: 0.42, fill: true,
          yAxisID: 'yVol', order: 2,
        },
        {   /* order count — green bars */
          type: 'bar', label: 'Orders',
          data: ordersData,
          backgroundColor: gradOrders, borderColor: '#33FF99',
          borderWidth: 1.5, borderRadius: 9,
          barPercentage: 0.7, categoryPercentage: 0.78,
          yAxisID: 'yOrders', order: 1,
        },
      ]
    },
    options: {
      maintainAspectRatio: false, responsive: true, animation: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(10,16,21,.95)',
          borderColor: 'rgba(51,255,153,.15)', borderWidth: 1,
          padding: 12, titleColor: '#fff', bodyColor: '#dbe6ea',
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#9db0b5', font: { size: 20 } } },
        yOrders: {
          position: 'left', beginAtZero: true,
          grid: { color: 'rgba(255,255,255,.07)' },
          ticks: { color: '#8fe6bc', font: { size: 19 } }
        },
        yVol: {
          position: 'right', beginAtZero: true,
          grid: { drawOnChartArea: false },
          ticks: {
            color: 'rgba(255,195,60,.8)',
            font: { size: 19 },
            callback: v => {
              if (v >= 1_000_000) return '$' + (v / 1_000_000).toFixed(1) + 'M';
              if (v >= 1_000)     return '$' + (v / 1_000).toFixed(0) + 'K';
              return '$' + v;
            }
          }
        },
      }
    }
  });

  // ── traders mini chart ────────────────────────────────────
  const tradersCtx = document.getElementById('tradersChart').getContext('2d');
  const gradTraders = tradersCtx.createLinearGradient(0, 0, 0, 140);
  gradTraders.addColorStop(0, 'rgba(35,220,200,.30)');
  gradTraders.addColorStop(1, 'rgba(35,220,200,.02)');

  new Chart(tradersCtx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        data: traderData,
        backgroundColor: gradTraders,
        borderColor: '#23DCC8',
        borderWidth: 1.5,
        borderRadius: 7,
        barPercentage: 0.7,
        categoryPercentage: 0.78,
      }]
    },
    options: {
      maintainAspectRatio: false, responsive: true, animation: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(10,16,21,.95)',
          borderColor: 'rgba(35,220,200,.15)', borderWidth: 1,
          padding: 10, titleColor: '#fff', bodyColor: '#dbe6ea',
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#9db0b5', font: { size: 18 } } },
        y: {
          position: 'left',
          beginAtZero: true,
          grid: { color: 'rgba(255,255,255,.05)' },
          ticks: { color: '#6ae9e0', font: { size: 17 }, maxTicksLimit: 3 }
        },
        yRight: {
          position: 'right',
          beginAtZero: true,
          grid: { drawOnChartArea: false },
          ticks: {
            color: 'transparent',
            font: { size: 19 },
            callback: v => {
              if (v >= 1_000_000) return '$' + (v / 1_000_000).toFixed(1) + 'M';
              if (v >= 1_000)     return '$' + (v / 1_000).toFixed(0) + 'K';
              return '$' + v;
            }
          }
        },
      }
    }
  });
</script>

{% endblock %}
