{% set _width, _height = set_viewport_size(1280, 720) %}
{% extends "base.jinja2" %}

{% block content %}
    <style>

        /* ── main layout ─────────────────────────────────────────── */
        .main-container {
            display: flex;
            flex-direction: row;
            gap: 18px;
            align-items: stretch;
        }

        .block-outer {
            display: flex;
            flex: 1;
            flex-direction: column;
            gap: 10px;
            min-height: 0;
        }

        /* ── panel card ──────────────────────────────────────────── */
        .block-inner {
            display: flex;
            flex: 1;
            padding: 18px 20px;
            flex-direction: column;
            gap: 12px;
            border-radius: 20px;
            background: linear-gradient(180deg, rgba(15,24,30,.97), rgba(9,14,19,.98));
            border: 1px solid rgba(255,255,255,.06);
            min-height: 0;
            overflow: hidden;
        }

        /* ── column / section titles ─────────────────────────────── */
        .block-title {
            display: block;
            color: #fff;
            font-size: 24px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .1em;
            text-align: left;
            width: 100%;
            margin-bottom: 2px;
        }

        /* ── metric blocks ───────────────────────────────────────── */
        .metric-block {
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        .metric-value-block {
            display: flex;
            flex-direction: row;
            align-items: baseline;
            gap: 14px;
        }

        .metric-title {
            color: #91a3a9;
            font-size: 18px;
            text-transform: uppercase;
            letter-spacing: .14em;
            font-weight: 400;
            margin-bottom: 4px;
        }

        .metric-value {
            font-size: 42px;
            font-weight: 800;
            color: #fff;
            line-height: 1;
            text-shadow: rgba(35,220,200,.12) 0 0 14px;
        }

        .metric-delta { font-weight: 800; font-size: 20px; }

        /* ── first-column inner wrapper ──────────────────────────── */
        .column {
            display: flex;
            flex: 1;
            flex-direction: column;
            align-items: stretch;
            justify-content: space-between;
            width: 100%;
        }

        /* ── delta arrow colours (override common.css) ───────────── */
        .up-arrow   { color: #33FF99 !important; }
        .down-arrow { color: #ff7f8a !important; }

        /* ── vault rows ──────────────────────────────────────────── */
        .vault-asset-box {
            display: flex;
            width: 100%;
            flex-direction: row;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,.05);
        }

        .coin { width: 52px; height: 52px; flex-shrink: 0; }

        .vault-amount {
            display: flex;
            font-size: 36px;
            font-weight: 800;
            color: #fff;
            flex: 1;
        }

        .vault-delta { font-weight: 800; font-size: 19px; }

        .coins-stack {
            position: relative;
            display: inline-block;
            width: 80px;
            height: 52px;
            flex-shrink: 0;
        }

        .coins-stack .coin { position: absolute; top: 0; border-radius: 50%; }
        .coins-stack .coin:nth-child(1) { transform: translate(0%); }
        .coins-stack .coin:nth-child(2) { transform: translate(50%); }

        .lefter {
            padding: 10px 0 10px 4px;
            border-bottom: 1px solid rgba(255,255,255,.05);
        }

        /* ── affiliate table ─────────────────────────────────────── */
        .affiliate-table {
            display: flex;
            flex-direction: column;
            gap: 4px;
            width: 100%;
        }

        .affiliate-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 7px;
            padding: 4px 0;
            border-bottom: 1px solid rgba(255,255,255,.04);
        }

        .affiliate-logo {
            height: 26px;
            width: 26px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .affiliate-name  { font-size: 18px; font-weight: 700; color: #d8e8ec; flex: 1; }
        .affiliate-volume { font-size: 18px; font-weight: 700; color: #fff; }
        .affiliate-delta  { font-size: 17px; }

        /* ── route table ─────────────────────────────────────────── */
        .route-table { display: flex; flex-direction: column; gap: 2px; }

        .route-row {
            display: flex;
            flex-direction: row;
            gap: 6px;
            font-size: 17px;
            font-weight: 700;
            padding: 4px 0;
            border-bottom: 1px solid rgba(255,255,255,.04);
            align-items: center;
        }

        .route-from, .route-to { color: #fff; }
        .route-arrow  { color: #23DCC8; font-size: 13px; }
        .route-volume { margin-left: auto; color: #b4c4c9; font-weight: 600; font-size: 16px; }

        /* ── swap-type bar ───────────────────────────────────────── */
        .bar-block { width: 100%; }

        .bar-wrap {
            position: relative;
            width: 100%;
        }

        .bar-container {
            width: 100%;
            height: 14px;
            display: flex;
            border-radius: 6px;
            overflow: hidden;
            background: rgba(255,255,255,.07);
        }

        .bar-segment { height: 100%; }

        /* tick = thin dark line that straddles the bar top/bottom */
        .bar-tick {
            position: absolute;
            bottom: 0;
            width: 2px;
            height: 22px;           /* 14px bar + 8px above */
            background: rgba(0,0,0,.70);
            transform: translateX(-50%);
            z-index: 2;
            border-radius: 1px;
        }


        .bar-labels {
            display: flex;
            justify-content: space-between;
            margin-top: 8px;
            font-size: 15px;
            font-weight: 700;
        }

        /* ── period pill ─────────────────────────────────────────── */
        .period-pill {
            position: absolute;
            top: 38px; right: 32px;
            padding: 9px 16px;
            border-radius: 12px;
            background: rgba(18,34,37,.85);
            border: 1px solid rgba(55,255,173,.16);
            text-align: right;
        }

        .period-main {
            font-size: 20px; font-weight: 700; color: #fff;
            text-transform: uppercase; letter-spacing: .08em;
        }

        .period-sub { font-size: 14px; color: #97b8b0; margin-top: 2px; }

    </style>

    {% with title="WEEKLY STATS" %}
        {% include "components/header.jinja2" %}
    {% endwith %}

    {% if start_date_ts and end_date_ts %}
    <div class="period-pill shadow-box">
        <div class="period-main">
            {{ datetimeformat(start_date_ts, "%d.%m.%Y") }} – {{ datetimeformat(end_date_ts, "%d.%m.%Y") }}
        </div>
    </div>
    {% endif %}

    <div class="main-container">
        <!-- COLUMN1 -->
        <div class="block-outer">
            <div class="block-title">Native asset vaults</div>
            <div class="block-inner shadow-box">
                <div class="column gapped">
                    <div class="vault-asset-box">
                        <img class="coin" alt="BTC logo" src="renderer/logo/BTC.BTC.png"/>

                        <div class="vault-amount single-amount">
                            {{ pretty_money(current.btc_total_amount) }} ₿
                        </div>

                        <div class="vault-delta">
                            {% with curr=current.btc_total_amount, prev=previous.btc_total_amount %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>

                    </div>

                    <div class="vault-asset-box">
                        <img class="coin" alt="ETH logo" src="renderer/logo/ETH.ETH.png"/>

                        <div class="vault-amount single-amount">
                            {{ pretty_money(current.eth_total_amount) }} Ξ
                        </div>

                        <div class="vault-delta">
                            {% with curr=current.eth_total_amount, prev=previous.eth_total_amount %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>

                    </div>

                    <div class="vault-asset-box">
                        <div class="coins-stack">
                            <img class="coin img-vault-asset" alt="USDT logo"
                                 src="renderer/logo/ETH.USDT-0XDAC17F958D2EE523A2206206994597C13D831EC7.png"/>
                            <img class="coin img-vault-asset" alt="USDC logo"
                                 src="renderer/logo/ETH.USDC-0XA0B86991C6218B36C1D19D4A2E9EB0CE3606EB48.png"/>
                        </div>

                        <div class="vault-amount">
                            ${{ short_money(current.usd_total_amount) }}
                        </div>

                        <div class="vault-delta">
                            {% with curr=current.usd_total_amount, prev=previous.usd_total_amount %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>

                    <div class="metric-block lefter">
                        <div class="metric-title">Native Asset Pooled</div>
                        <div class="metric-value-block">
                            <div class="metric-value">
                                {{ short_dollar(current.lock.total_non_rune_usd) }}
                            </div>

                            <div class="metric-delta">
                                {% with curr=current.lock.total_non_rune_usd, prev=previous.lock.total_non_rune_usd %}
                                    {% include "components/delta.jinja2" %}
                                {% endwith %}
                            </div>
                        </div>
                    </div>

                    <div class="metric-block lefter">
                        <div class="metric-title">Network security</div>
                        <div class="metric-value-block">
                            <div class="metric-value">
                                {{ short_dollar(current.lock.total_value_bonded_usd) }}
                            </div>
                            <div class="metric-delta">
                                {% with curr=current.lock.total_value_bonded_usd, prev=previous.lock.total_value_bonded_usd %}
                                    {% include "components/delta.jinja2" %}
                                {% endwith %}
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>

        <!-- COLUMN2 -->
        <div class="block-outer">
            <div class="block-title">Protocol revenue</div>

            <div class="block-inner shadow-box gapped">
                <div class="metric-block">
                    <div class="metric-title">Protocol Revenue</div>
                    <div class="metric-value-block">
                        <div class="metric-value">
                            {{ short_dollar(current.earnings.total_earnings) }}
                        </div>
                        <div class="metric-delta">
                            {% with curr=current.earnings.total_earnings, prev=previous.earnings.total_earnings %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>
                </div>

                <div class="metric-block">
                    <div class="metric-title">Affiliate Revenue</div>

                    <div class="metric-value-block">
                        <div class="metric-value">
                            {{ short_dollar(current.earnings.affiliate_revenue * 0.01) }}
                        </div>
                        <div class="metric-delta">
                            {% with curr=current.earnings.affiliate_revenue, prev=previous.earnings.affiliate_revenue %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>
                </div>

                <div class="metric-block">
                    <div class="metric-title">Top affiliates</div>

                    <div class="affiliate-table">
                        {% for aff in top_affiliates[:7] %}
                            <div class="affiliate-row">

                                <img src="{{ aff["logo"] or "renderer/logo/unknown.png" }}"
                                     alt="{{ aff["display_name"] }} logo" class="affiliate-logo">

                                <div class="affiliate-name">{{ aff["display_name"] }}</div>

                                <div class="affiliate-volume">
                                    {{ short_dollar(aff.total_usd * 0.01) }}
                                </div>
                                <div class="affiliate-delta">
                                    {% with curr=aff.total_usd, prev=aff.prev_total_usd %}
                                        {% include "components/delta.jinja2" %}
                                    {% endwith %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <!-- COLUMN3 -->
        <div class="block-outer">
            <div class="block-title">Swap info</div>
            <div class="block-inner shadow-box gapped">
                <div class="metric-block">
                    <div class="metric-title">
                        Unique Swappers
                    </div>
                    <div class="metric-value-block">
                        <div class="metric-value">
                            {{ pretty_money(current.swapper_count, integer=True) }}
                        </div>
                        <div class="metric-delta">
                            {% with curr=current.swapper_count, prev=previous.swapper_count %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>
                </div>

                <div class="metric-block">
                    <div class="metric-title">
                        Swap Volume
                    </div>
                    <div class="metric-value-block">
                        <div class="metric-value">
                            {{ short_dollar(current.total_volume_usd) }}
                        </div>
                        <div class="metric-delta">
                            {% with curr=current.total_volume_usd, prev=previous.total_volume_usd %}
                                {% include "components/delta.jinja2" %}
                            {% endwith %}
                        </div>
                    </div>
                </div>

                <div class="metric-block">
                    <div class="metric-title">Top Route</div>
                    <div class="route-table">
                        {% for route in routes[:7] %}
                            <div class="route-row">
                                <div class="route-from">{{ route['from_asset'] }}</div>
                                <div class="route-arrow">⇌</div>
                                <div class="route-to">{{ route['to_asset'] }}</div>
                                <div class="route-volume up-arrow">{{ short_money(route['volume_usd'], integer=True) }}</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="bar-block">
                    {% set pct_swap  = swap_type_distribution.get('swap', 0) * 100 %}
                    {% set pct_trade = swap_type_distribution.get('trade_swap', 0) * 100 %}
                    {% set pct_sec   = swap_type_distribution.get('secured_swap', 0) * 100 %}
                    {% set tick1 = pct_swap %}
                    {% set tick2 = pct_swap + pct_trade %}

                    <div class="bar-wrap">
                        <div class="bar-container">
                            <div class="bar-segment highlight-blue-bg"
                                 style="width: {{ pct_swap }}%"></div>
                            <div class="bar-segment midgard-turqoise-bg"
                                 style="width: {{ pct_trade }}%"></div>
                            <div class="bar-segment yggdrasil-green-bg"
                                 style="width: {{ pct_sec }}%"></div>
                        </div>

                        {% if tick1 > 1 and tick1 < 99 %}
                        <div class="bar-tick" style="left: {{ tick1 }}%"></div>
                        {% endif %}

                        {% if tick2 > 1 and tick2 < 99 and (tick2 - tick1) > 2 %}
                        <div class="bar-tick" style="left: {{ tick2 }}%"></div>
                        {% endif %}
                    </div>

                    <div class="bar-labels">
                        <span class="highlight-blue">Ordinary {{ pct_swap | round(1) }}%</span>
                        <span class="midgard-turqoise">Trade {{ pct_trade | round(1) }}%</span>
                        <span class="yggdrasil-green">Secured {{ pct_sec | round(1) }}%</span>
                    </div>
                </div>
            </div>


        </div>
    </div>

    <script>
        // todo

    </script>

{% endblock %}
